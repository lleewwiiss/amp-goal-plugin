{
  "name": "amp-goal-plugin",
  "version": "0.1.0",
  "description": "Compaction-safe goal and workflow continuation plugin for Amp.",
  "keywords": [
    "amp",
    "ampcode",
    "autonomous-agent",
    "goal",
    "handoff",
    "plugin",
    "workflow"
  ],
  "homepage": "https://github.com/lleewwiiss/amp-goal-plugin#readme",
  "bugs": {
    "url": "https://github.com/lleewwiiss/amp-goal-plugin/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lleewwiiss/amp-goal-plugin.git"
  },
  "files": [
    "src/goal.ts",
    "README.md"
  ],
  "type": "module",
  "scripts": {
    "check": "bun run typecheck && bun run lint && bun test && bun run format:check",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "install:plugin": "mkdir -p ~/.config/amp/plugins && cp src/goal.ts ~/.config/amp/plugins/goal.ts",
    "lint": "oxlint .",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@ampcode/plugin": "0.0.0-20260709003202-g32d9f9d",
    "@nkzw/eslint-plugin": "^2.0.0",
    "@nkzw/oxlint-config": "^1.2.1",
    "eslint-plugin-no-only-tests": "^3.4.0",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "typescript": "^5.9.3"
  }
}
